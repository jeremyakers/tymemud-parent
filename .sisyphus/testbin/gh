#!/usr/bin/env bash
set -euo pipefail

cmd="${1:-}"
shift || true

if [[ "$cmd" == "auth" && "${1:-}" == "status" ]]; then
    exit 0
fi

if [[ "$cmd" == "pr" && "${1:-}" == "view" ]]; then
    shift
    pr_num="$1"
    shift
    joined=" $* "
    repo="example/repo"

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --repo)
                repo="$2"
                shift 2
                ;;
            *)
                shift
                ;;
        esac
    done

    if [[ "$joined" == *" --json headRefOid "* ]]; then
        printf 'sha-%s\n' "$pr_num"
        exit 0
    fi

    if [[ "$joined" == *" --json number,title,state,url "* || "$joined" == *" --json title,state,url "* ]]; then
        printf '{"title":"Mock PR %s","state":"OPEN","url":"https://github.com/%s/pull/%s"}\n' "$pr_num" "$repo" "$pr_num"
        exit 0
    fi

    if [[ "$joined" == *" --json number "* ]]; then
        printf '{"number":%s}\n' "$pr_num"
        exit 0
    fi
fi

if [[ "$cmd" == "api" ]]; then
    fixture_run_id="${GH_FIXTURE_RUN_ID:-${PPID:-unknown}}"
    if [[ -d ".sisyphus/evidence" ]]; then
        fixture_dir=".sisyphus/evidence/gh-fixture-${fixture_run_id}"
    else
        fixture_dir="${TMPDIR:-/tmp}/tymemud-gh-fixture-${fixture_run_id}"
    fi
    mkdir -p "$fixture_dir"

    endpoint=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --paginate)
                shift
                ;;
            -H|--header|--jq|-X|--method|-F|-f)
                shift 2
                ;;
            --*)
                shift
                ;;
            *)
                endpoint="$1"
                break
                ;;
        esac
    done

    log_endpoint_call() {
        local bucket="$1"
        local counter_file="$fixture_dir/$bucket.count"
        local count=0

        if [[ -f "$counter_file" ]]; then
            count=$(<"$counter_file")
        fi

        count=$((count + 1))
        printf '%s\n' "$count" >"$counter_file"
        printf 'fixture gh %s call=%s endpoint=%s\n' "$bucket" "$count" "$endpoint" >&2
    }

    case "$endpoint" in
        repos/example/repo/commits/sha-102|repos/example/repo/commits/sha-103|repos/example/repo/commits/sha-104|repos/example/repo/commits/sha-105|repos/example/repo/commits/sha-106|repos/example/other/commits/sha-201)
            printf '2026-04-18T10:00:00Z\n'
            exit 0
            ;;
        repos/example/repo/issues/102/comments\?per_page=100)
            printf '[]\n'
            exit 0
            ;;
        repos/example/repo/issues/105/comments\?per_page=100)
            printf '[{"id":1051,"created_at":"2026-04-18T10:10:00Z","user":{"login":"reviewer"},"body":"Please address the failing edge case."},{"id":1052,"created_at":"2026-04-18T10:15:00Z","user":{"login":"chatgpt-codex-connector[bot]"},"body":"Codex Review: Didn'"'"'t find any major issues."}]\n'
            exit 0
            ;;
        repos/example/repo/issues/106/comments\?per_page=100)
            printf '[{"id":1061,"created_at":"2026-04-18T09:55:00Z","user":{"login":"reviewer"},"body":"Earlier context."}]\n'
            exit 0
            ;;
        repos/example/repo/issues/104/comments\?per_page=100)
            printf '[{"id":1041,"created_at":"2026-04-18T10:12:00Z","user":{"login":"chatgpt-codex-connector[bot]"},"body":"Codex Review: Didn'"'"'t find any major issues."}]\n'
            exit 0
            ;;
        repos/example/other/issues/201/comments\?per_page=100)
            printf '[]\n'
            exit 0
            ;;
        repos/example/repo/issues/103/comments\?per_page=100)
            log_endpoint_call top_level_issue_comments
            printf '[{"id":1031,"created_at":"2026-04-18T09:55:00Z","user":{"login":"reviewer"},"body":"Earlier context."}]\n'
            exit 0
            ;;
        repos/example/repo/pulls/102/comments\?per_page=100|repos/example/repo/pulls/104/comments\?per_page=100|repos/example/repo/pulls/105/comments\?per_page=100|repos/example/repo/pulls/106/comments\?per_page=100|repos/example/other/pulls/201/comments\?per_page=100)
            printf '[]\n'
            exit 0
            ;;
        repos/example/repo/pulls/103/comments\?per_page=100)
            log_endpoint_call top_level_review_comments
            printf '[{"id":1032,"created_at":"2026-04-18T09:56:00Z","user":{"login":"reviewer"},"body":"Earlier inline note.","path":"src/mock.c","line":12,"original_line":12,"start_line":12,"end_line":12,"commit_id":"deadbeef103"}]\n'
            exit 0
            ;;
        repos/example/repo/pulls/102/reviews\?per_page=100|repos/example/repo/pulls/104/reviews\?per_page=100|repos/example/repo/pulls/105/reviews\?per_page=100|repos/example/repo/pulls/106/reviews\?per_page=100|repos/example/other/pulls/201/reviews\?per_page=100)
            printf '[]\n'
            exit 0
            ;;
        repos/example/repo/pulls/103/reviews\?per_page=100)
            log_endpoint_call top_level_reviews
            printf '[]\n'
            exit 0
            ;;
        repos/example/repo/issues/comments/1021/reactions\?per_page=100|repos/example/repo/issues/comments/1041/reactions\?per_page=100|repos/example/repo/issues/comments/1051/reactions\?per_page=100|repos/example/repo/issues/comments/1052/reactions\?per_page=100)
            printf '[]\n'
            exit 0
            ;;
        repos/example/repo/issues/comments/1061/reactions\?per_page=100)
            log_endpoint_call nested_issue_reactions
            reaction_call_count=$(<"$fixture_dir/nested_issue_reactions.count")
            if (( reaction_call_count == 1 )); then
                printf '[]\n'
            else
                printf '[{"id":2061,"created_at":"2026-04-18T10:06:00Z","user":{"login":"chatgpt-codex-connector[bot]"},"content":"+1"}]\n'
            fi
            exit 0
            ;;
        repos/example/repo/issues/comments/1031/reactions\?per_page=100)
            log_endpoint_call nested_issue_reactions
            printf '[]\n'
            exit 0
            ;;
        repos/example/repo/pulls/comments/1032/reactions\?per_page=100)
            log_endpoint_call nested_review_reactions
            printf '[]\n'
            exit 0
            ;;
        repos/example/repo/issues/102/reactions\?per_page=100)
            printf '[{"id":2021,"created_at":"2026-04-18T10:05:00Z","user":{"login":"chatgpt-codex-connector[bot]"},"content":"+1"}]\n'
            exit 0
            ;;
        repos/example/repo/issues/104/reactions\?per_page=100|repos/example/repo/issues/105/reactions\?per_page=100|repos/example/repo/issues/106/reactions\?per_page=100|repos/example/other/issues/201/reactions\?per_page=100)
            printf '[]\n'
            exit 0
            ;;
        repos/example/repo/issues/103/reactions\?per_page=100)
            log_endpoint_call top_level_pr_reactions
            printf '[]\n'
            exit 0
            ;;
    esac
fi

printf 'mock gh: unsupported invocation:' >&2
printf ' %q' "$cmd" "$@" >&2
printf '\n' >&2
exit 1
