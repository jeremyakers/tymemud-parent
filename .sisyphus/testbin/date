#!/usr/bin/env bash
set -euo pipefail

if [[ "${GH_FIXTURE_TIME_SCENARIO:-}" != "polling-nested-handoff" || "${1:-}" != "+%s" ]]; then
    exec /usr/bin/date "$@"
fi

run_id="${GH_FIXTURE_RUN_ID:-${PPID:-unknown}}"
if [[ -d ".sisyphus/evidence" ]]; then
    state_dir=".sisyphus/evidence/gh-fixture-${run_id}"
else
    state_dir="${TMPDIR:-/tmp}/tymemud-gh-fixture-${run_id}"
fi

mkdir -p "$state_dir"
counter_file="$state_dir/date.count"
count=0

if [[ -f "$counter_file" ]]; then
    count=$(<"$counter_file")
fi

count=$((count + 1))
printf '%s\n' "$count" >"$counter_file"

case "$count" in
    1) printf '1000\n' ;;
    2) printf '1301\n' ;;
    *) printf '1301\n' ;;
esac
